{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro MPesaTanzaniaParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/MPesaTanzaniaParser.kt). M-Pesa Tanzania (Vodacom) is a mobile-money wallet: messages carry no bank account number, so accountLast4 falls back to \"0000\" (same rationale as jiopay.ts — the original parser leaves it null). Kotlin's isTransactionMessage requires BOTH \"confirmed\" and \"tzs\" in addition to a transaction keyword; the declarative filter can only express the keyword OR-list, so the confirmed/tzs requirements are enforced as pipeline rejectWhen steps (yielding REVIEW + FILTER_REJECTED rather than a hard REJECTED — closest faithful approximation)."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "tz.mpesa.wallet",
    "type": "sms-parser",
    "name": "M-Pesa Tanzania",
    "country": "TZ",
    "currency": "TZS",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["MPESA", "M-PESA", "VODACOM"],
      "dltPatterns": ["^.*M-?PESA.*$", "^.*VODACOM.*$"]
    },
    "filter": {
      "requireAnyKeyword": ["received", "sent to", "paid to", "withdrawn", "new m-pesa balance"]
    },
    "extract": {
      "amount": [
        {
          "re": "TZS\\s+(?<value>[0-9,]+(?:\\.[0-9]{2})?)"
        },
        {
          "re": "TZS(?<value>[0-9,]+(?:\\.[0-9]{2})?)"
        }
      ],
      "merchant": [
        {
          "re": "from\\s+(?<value>[A-Z][A-Za-z\\s]+?)(?:\\s*\\(|$)"
        },
        {
          "re": "sent to\\s+(?<value>[A-Z][A-Za-z\\s]+?)(?:\\s*\\(|$)"
        },
        {
          "re": "paid to\\s+(?<value>[A-Za-z0-9\\s]+?)(?:\\s*\\(Merchant|\\s+on|\\s*$)"
        },
        {
          "re": "paid to\\s+(?<value>\\w+)\\s+for\\s+account"
        }
      ],
      "balance": [
        {
          "re": "New M-Pesa balance is TZS\\s*(?<value>[0-9,]+(?:\\.[0-9]{2})?)"
        }
      ],
      "reference": [
        {
          "re": "^(?<value>[A-Z0-9]{10})\\s+Confirmed"
        },
        {
          "re": "TIPS\\s+Reference[:\\s]+(?<value>[A-Z0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "(?:A/c|Account|Acct)(?:\\s+No)?\\.?\\s+(?:[Xx*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "expense": ["sent to", "paid to", "withdrawn"]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s*\\(.*?\\)\\s*$",
        "\\s+on\\s+\\d{4}.*",
        "\\s+at\\s+\\d{2}:\\d{2}.*",
        "\\s*-\\s*$"
      ],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "rejectWhen",
        "when": {
          "notContainsAny": ["tzs"]
        },
        "reason": "FILTER_REJECTED"
      },
      {
        "kind": "rejectWhen",
        "when": {
          "notContainsAny": ["confirmed"]
        },
        "reason": "FILTER_REJECTED"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["you have received", "received tsh", "received tzs"]
        },
        "field": "transactionType",
        "value": "INCOME"
      },
      {
        "kind": "fallbackField",
        "field": "accountLast4",
        "value": "0000"
      }
    ]
  },
  "fixtures": [
    {
      "name": "received money (P2P in)",
      "sender": "M-PESA",
      "receivedAt": "2025-05-12T10:30:00.000Z",
      "body": "SGR1234567 Confirmed. You have received TZS 50,000.00 from JOHN DOE (255754XXXXXX) on 2025-05-12 at 10:30 AM. New M-Pesa balance is TZS 150,000.00.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "50000.00",
          "merchant": "JOHN DOE",
          "transactionType": "INCOME",
          "balance": "150000.00",
          "reference": "SGR1234567",
          "accountLast4": "0000"
        }
      }
    },
    {
      "name": "sent money (P2P out)",
      "sender": "M-PESA",
      "receivedAt": "2025-05-12T11:45:00.000Z",
      "body": "SGR9876543 Confirmed. TZS 20,000.00 sent to JANE SMITH (255762XXXXXX) on 2025-05-12 at 11:45 AM. Transaction cost TZS 500.00. New M-Pesa balance is TZS 129,500.00.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "20000.00",
          "merchant": "JANE SMITH",
          "transactionType": "EXPENSE",
          "balance": "129500.00",
          "reference": "SGR9876543",
          "accountLast4": "0000"
        }
      }
    },
    {
      "name": "lipa kwa m-pesa merchant payment",
      "sender": "M-PESA",
      "receivedAt": "2025-05-13T20:20:00.000Z",
      "body": "SGR5544332 Confirmed. TZS 15,000.00 paid to SUPERMARKET X (Merchant ID: 556677) on 2025-05-13 at 08:20 PM. Transaction cost TZS 0.00. New M-Pesa balance is TZS 114,500.00.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "15000.00",
          "merchant": "SUPERMARKET X",
          "transactionType": "EXPENSE",
          "balance": "114500.00",
          "reference": "SGR5544332",
          "accountLast4": "0000"
        }
      }
    },
    {
      "name": "LUKU utility payment",
      "sender": "M-PESA",
      "receivedAt": "2025-05-14T09:00:00.000Z",
      "body": "SGR1122334 Confirmed. TZS 10,000.00 paid to LUKU for account 1423XXXXXXX. Token: 1234-5678-9012-3456-7890. Transaction cost TZS 0.00. New M-Pesa balance is TZS 104,500.00.",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "10000.00",
          "merchant": "LUKU",
          "transactionType": "EXPENSE",
          "balance": "104500.00",
          "reference": "SGR1122334",
          "accountLast4": "1423"
        }
      }
    },
    {
      "name": "PIN/OTP message is filter-rejected",
      "sender": "M-PESA",
      "receivedAt": "2025-05-15T08:00:00.000Z",
      "body": "Your M-Pesa PIN change verification code is 123456. Do not share this code with anyone. Vodacom will never ask for your PIN.",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
