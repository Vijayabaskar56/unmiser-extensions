{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro DBSBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/DBSBankParser.kt) plus the BankParser.kt base-class fallbacks the Kotlin parser defers to via super.extractX(...). DBS Bank India (digibank) — currency INR, Indian DLT sender headers. No original Kotlin tests exist for this parser, so fixtures are synthesized from the parser's regexes and doc comments (\"debited with INR 11\", \"account no ********1234\", \"Current Balance is INR37888.45\")."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.dbs.bank",
    "type": "sms-parser",
    "name": "DBS Bank",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["DBS", "DBSBNK", "DBSBANK"],
      "dltPatterns": [
        "^[A-Z]{2}-DBSBNK-[ST]$",
        "^[A-Z]{2}-DBS-[ST]$",
        "^[A-Z]{2}-DBSBANK-[ST]$",
        "DBSBNK",
        "DBS"
      ]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "offer",
        "discount",
        "win ",
        "has requested",
        "payment request",
        "collect request",
        "requesting payment",
        "requests rs",
        "ignore if already paid",
        "have received payment",
        "is due",
        "min amount due",
        "minimum amount due",
        "in arrears",
        "is overdue",
        "ignore if paid"
      ],
      "requireAnyKeyword": [
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "(?:debited|credited)\\s+with\\s+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)\\s+(?:debited|credited)"
        },
        {
          "re": "Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "merchant": [
        {
          "re": "to\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "from\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "at\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+Ref)"
        },
        {
          "re": "for\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref)"
        }
      ],
      "balance": [
        {
          "re": "Current\\s+Balance\\s+is\\s+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Balance[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avl\\s+Bal[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Updated Balance|Remaining Balance)[:\\s]+(?:Rs\\.?|INR)\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "reference": [
        {
          "re": "(?:Ref|Reference|Txn|Transaction)(?:\\s+No)?[:\\s]+(?<value>[A-Z0-9]+)"
        },
        {
          "re": "UPI[:\\s]+(?<value>[0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "account\\s+no\\s+\\*+(?<value>\\d{4})"
        },
        {
          "re": "a/c\\s+\\*+(?<value>\\d{4})"
        },
        {
          "re": "account\\s+\\*+(?<value>\\d{4})"
        },
        {
          "re": "(?:A/c|Account|Acct)(?:\\s+No)?\\.?\\s+(?:[Xx*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Card\\s+(?:[Xx*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "investment": [
        "iccl",
        "nsccl",
        "groww",
        "zerodha",
        "sip",
        "mutual fund",
        "demat",
        "smallcase"
      ],
      "expense": ["spent", "charged", "paid", "purchase", "deducted"],
      "income": ["received", "refund"]
    },
    "cardRules": {
      "excludeKeywords": ["a/c", "account", "ac ", "acc ", "saving account", "current account"],
      "includeKeywords": [
        "card ending",
        "card xx",
        "debit card",
        "credit card",
        "card no.",
        "card number",
        "card *",
        "card x"
      ]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s*\\(.*?\\)\\s*$",
        "\\s+Ref\\s+No.*",
        "\\s+on\\s+\\d{2}.*",
        "\\s+UPI.*",
        "\\s+at\\s+\\d{2}:\\d{2}.*",
        "\\s*-\\s*$",
        "(\\s+PVT\\.?\\s*LTD\\.?|\\s+PRIVATE\\s+LIMITED)$",
        "(\\s+LTD\\.?|\\s+LIMITED)$"
      ],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["credited", "deposited"]
        },
        "field": "transactionType",
        "value": "INCOME"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["debited", "withdrawn"]
        },
        "field": "transactionType",
        "value": "EXPENSE"
      }
    ]
  },
  "fixtures": [
    {
      "name": "upi debit with current balance",
      "sender": "VM-DBSBNK-S",
      "receivedAt": "2026-06-09T10:00:00.000Z",
      "body": "Your account no ********1234 is debited with INR 500.00 on 09-06-2026 to Amazon Pay India Ref no 123456789012. Current Balance is INR37888.45",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "merchant": "Amazon Pay India",
          "accountLast4": "1234",
          "balance": "37888.45",
          "transactionType": "EXPENSE",
          "reference": "123456789012"
        }
      }
    },
    {
      "name": "neft credit with avl bal",
      "sender": "AD-DBS-S",
      "receivedAt": "2026-06-01T09:30:00.000Z",
      "body": "Your a/c ****5678 is credited with INR 25,000.00 on 01-06-2026 from ACME CORP Ref UTIB12345. Avl Bal: INR 60,000.00",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "25000.00",
          "merchant": "ACME CORP",
          "accountLast4": "5678",
          "balance": "60000.00",
          "transactionType": "INCOME",
          "reference": "UTIB12345"
        }
      }
    },
    {
      "name": "atm withdrawal via base fallback patterns",
      "sender": "JD-DBSBANK-T",
      "receivedAt": "2026-06-05T18:45:00.000Z",
      "body": "INR 2000.00 withdrawn at DBS ATM CITYBRANCH on 05-06-2026 using your DBS debit card. Account no ******4321. Avl Bal: INR 15,400.50",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "2000.00",
          "merchant": "DBS ATM CITYBRANCH",
          "accountLast4": "4321",
          "balance": "15400.50",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "cash deposit with current balance",
      "sender": "VK-DBSBNK-S",
      "receivedAt": "2026-06-03T11:15:00.000Z",
      "body": "INR 1,000.00 deposited in cash at DBS Bank Branch MG Road on 03-06-2026. Account no ****9876. Current Balance is INR5,500.00",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1000.00",
          "merchant": "DBS Bank Branch MG Road",
          "accountLast4": "9876",
          "balance": "5500.00",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "otp message is filter-rejected",
      "sender": "VM-DBSBNK-S",
      "receivedAt": "2026-06-09T10:01:00.000Z",
      "body": "Your OTP for DBS digibank transaction is 482910. Do not share it with anyone. -DBS Bank",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    },
    {
      "name": "payment request is filter-rejected",
      "sender": "VM-DBSBNK-S",
      "receivedAt": "2026-06-09T10:02:00.000Z",
      "body": "merchant@upi has requested INR 999.00 from your DBS account. Approve in digibank app. Ignore if already paid.",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
