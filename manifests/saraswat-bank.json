{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro SaraswatBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/SaraswatBankParser.kt). Formats: \"Your A/c no. NNNN is credited with INR X on DATE towards ACH Credit:MERCHANT. Current Bal is INR Y CR - Saraswat Bank\" and \"Dear Customer, Your account no. ending with NNNN is debited with INR X on DATE for S.I./NEFT/RTGS/IMPS. Current Bal is INR YCR. - Saraswat Bank\". The Kotlin \"for X\" merchant aliases (S.I -> Standing Instruction, NEFT -> NEFT Transfer, ...) and the ATM fallback are ported as pipeline steps."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.saraswat.bank",
    "type": "sms-parser",
    "name": "Saraswat Co-operative Bank",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["SARBNK", "SARASWAT", "SARASWATBANK"],
      "dltPatterns": [
        "^[A-Z]{2}-SARBNK-[ST]$",
        "^[A-Z]{2}-SARASWAT-[ST]$",
        "^[A-Z]{2}-SARBNK$",
        "^[A-Z]{2}-SARASWAT$"
      ]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "offer",
        "discount",
        "win ",
        "has requested",
        "payment request",
        "collect request",
        "requesting payment",
        "requests rs",
        "ignore if already paid"
      ],
      "requireAnyKeyword": [
        "is credited with",
        "is debited with",
        "credited with inr",
        "debited with inr",
        "current bal is",
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "INR\\s+(?<value>\\d+(?:,\\d{3})*(?:\\.\\d{2})?)"
        },
        {
          "re": "Rs\\.?\\s*(?<value>\\d+(?:,\\d{3})*(?:\\.\\d{2})?)"
        }
      ],
      "merchant": [
        {
          "re": "towards\\s+(?<value>.+?)(?:\\.\\s*Current|\\s*Current|$)"
        },
        {
          "re": "for\\s+(?<value>[A-Z.]+?)(?:\\.\\s+Current|\\s+Current|$)"
        }
      ],
      "balance": [
        {
          "re": "Current\\s+Bal\\s+is\\s+INR\\s+(?<value>\\d+(?:,\\d{3})*(?:\\.\\d{2})?)\\s*(?:CR|DR)?"
        },
        {
          "re": "Bal[:\\s]+Rs\\.?\\s*(?<value>\\d+(?:,\\d{3})*(?:\\.\\d{2})?)"
        }
      ],
      "accountLast4": [
        {
          "re": "A/c\\s+no\\.\\s+(?:ending\\s+with\\s+)?(?<value>\\d{4,6})",
          "takeLast4": true
        },
        {
          "re": "account\\s+no\\.\\s+ending\\s+with\\s+(?<value>\\d{4,6})",
          "takeLast4": true
        },
        {
          "re": "A/c\\s+\\*(?<value>\\d{4})"
        }
      ]
    },
    "typeRules": {
      "income": ["is credited", "credited with"],
      "expense": ["is debited", "debited with", "withdrawn"]
    },
    "cleaning": {
      "stripPatterns": ["^ACH\\s+Credit:\\s*", "^ACH\\s+Debit:\\s*"],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["ATM", "withdrawn"],
          "notContainsAny": ["towards"]
        },
        "field": "merchant",
        "value": "ATM Withdrawal"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["for S.I.", "for SI."]
        },
        "field": "merchant",
        "value": "Standing Instruction"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["for NEFT"]
        },
        "field": "merchant",
        "value": "NEFT Transfer"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["for RTGS"]
        },
        "field": "merchant",
        "value": "RTGS Transfer"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["for IMPS"]
        },
        "field": "merchant",
        "value": "IMPS Transfer"
      }
    ]
  },
  "fixtures": [
    {
      "name": "ach credit transaction",
      "sender": "JD-SARBNK-S",
      "receivedAt": "2025-10-13T10:00:00.000Z",
      "body": "Your A/c no. 1234 is credited with INR 100.50 on 13-10-2025 towards ACH Credit:MERCHANT NAME. Current Bal is INR 950.00 CR  - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "100.50",
          "merchant": "MERCHANT NAME",
          "accountLast4": "1234",
          "balance": "950.00",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "standing instruction debit",
      "sender": "JD-SARBNK-S",
      "receivedAt": "2025-09-25T10:00:00.000Z",
      "body": "Dear Customer, Your account no. ending with 5678 is debited with INR 1,000.00 on 25-09-2025  for S.I. Current Bal is INR 8,500.00CR. - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1000.00",
          "merchant": "Standing Instruction",
          "accountLast4": "5678",
          "balance": "8500.00",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "simple credit transaction",
      "sender": "SARBNK",
      "receivedAt": "2025-11-01T10:00:00.000Z",
      "body": "Your A/c no. 9012 is credited with INR 500.00 on 01-11-2025 towards Salary. Current Bal is INR 15,000.00 CR - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "merchant": "Salary",
          "accountLast4": "9012",
          "balance": "15000.00",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "large amount neft debit",
      "sender": "AD-SARBNK-S",
      "receivedAt": "2025-10-15T10:00:00.000Z",
      "body": "Dear Customer, Your account no. ending with 3456 is debited with INR 25,000.00 on 15-10-2025 for NEFT. Current Bal is INR 50,000.00CR. - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "25000.00",
          "merchant": "NEFT Transfer",
          "accountLast4": "3456",
