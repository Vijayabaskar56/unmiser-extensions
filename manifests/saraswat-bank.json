      "receivedAt": "2025-10-20T10:00:00.000Z",
      "body": "Your A/c no. 7890 is credited with INR 10.00 on 20-10-2025 towards Cashback. Current Bal is INR 1,200.50 CR - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "10.00",
          "merchant": "Cashback",
          "accountLast4": "7890",
          "balance": "1200.50",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "rtgs transfer debit",
      "sender": "JD-SARBNK-S",
      "receivedAt": "2025-10-22T10:00:00.000Z",
      "body": "Dear Customer, Your account no. ending with 2468 is debited with INR 50,000.00 on 22-10-2025 for RTGS. Current Bal is INR 100,000.00CR. - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "50000.00",
          "merchant": "RTGS Transfer",
          "accountLast4": "2468",
          "balance": "100000.00",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "imps transfer debit",
      "sender": "BV-SARBNK-S",
      "receivedAt": "2025-10-23T10:00:00.000Z",
      "body": "Dear Customer, Your account no. ending with 1357 is debited with INR 2,500.00 on 23-10-2025 for IMPS. Current Bal is INR 12,345.67CR. - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "2500.00",
          "merchant": "IMPS Transfer",
          "accountLast4": "1357",
          "balance": "12345.67",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "refund credit via alternative sender",
      "sender": "SARASWATBANK",
      "receivedAt": "2025-10-24T10:00:00.000Z",
      "body": "Your A/c no. 9753 is credited with INR 750.00 on 24-10-2025 towards Refund. Current Bal is INR 5,000.00 CR - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "750.00",
          "merchant": "Refund",
          "accountLast4": "9753",
          "balance": "5000.00",
          "transactionType": "INCOME"
        }
      }
    },
    {
      "name": "standing instruction debit without dots",
      "sender": "SARBNK",
      "receivedAt": "2025-01-02T10:00:00.000Z",
      "body": "Dear Customer, Your account no. ending with 5678 is debited with INR 500.00 on 02-01-2025 for SI. Current Bal is INR 2,000.00CR. - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "merchant": "Standing Instruction",
          "accountLast4": "5678",
          "balance": "2000.00",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "atm withdrawal (synthesized from kotlin pattern 3)",
      "sender": "JD-SARBNK-S",
      "receivedAt": "2025-10-12T10:00:00.000Z",
      "body": "INR 2,000.00 withdrawn from your A/c no. 4321 at ATM on 12-10-2025. Current Bal is INR 5,000.00 CR - Saraswat Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "2000.00",
          "merchant": "ATM Withdrawal",
          "accountLast4": "4321",
          "balance": "5000.00",
          "transactionType": "EXPENSE"
        }
      }
    },
    {
      "name": "otp message is filter-rejected",
      "sender": "JD-SARBNK-S",
      "receivedAt": "2025-10-10T10:00:00.000Z",
      "body": "Your OTP for Saraswat Bank Net Banking login is 482913. Do not share it with anyone. - Saraswat Bank",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
