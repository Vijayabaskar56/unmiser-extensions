{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Ported from the original Cashiro FABParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/FABParser.kt). First Abu Dhabi Bank (UAE) — multi-line card-purchase SMS where the merchant is the line after the \"<CCY> <amount>\" line, plus single-line funds transfer / payment instruction / remittance / cheque narratives. Known deviations from the Kotlin parser (engine limitations, see fixtures): - currency is always the manifest currency \"AED\"; the Kotlin parser extracted the per-transaction currency (THB/USD) from the body. - merchant whitespace is collapsed to single spaces by the engine cleaner (\"TR DUBAI ARE\" -> \"TR DUBAI ARE\"). - transfer merchants are the static \"Transfer\" instead of the Kotlin composed \"Transfer: 003 -> 002\" / \"Transfer to 1xxx\" strings."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "ae.fab.bank",
    "type": "sms-parser",
    "name": "First Abu Dhabi Bank",
    "country": "AE",
    "currency": "AED",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["FAB"],
      "dltPatterns": ["FABBANK", "ADFAB", "^[A-Z]{2}-FAB-[A-Z]$"]
    },
    "filter": {
      "excludeKeywords": [
        "declined due to insufficient balance",
        "transaction has been declined",
        "address update request",
        "statement request",
        "stamped statement",
        "cannot process your",
        "amazing rate",
        "request has been logged",
        "reference number",
        "beneficiary creation/modification request",
        "funds transfer request is under process",
        "has been resolved",
        "funds transfer request has failed",
        "card has been successfully activated",
        "temporarily blocked",
        "never share credit/debit card",
        "replacement request",
        "card will be ready for dispatch",
        "otp",
        "activation",
        "atyourservice@bankfab.com",
        "has been blocked on"
      ],
      "requireAnyKeyword": [
        "credit card purchase",
        "debit card purchase",
        "inward remittance",
        "outward remittance",
        "atm cash withdrawal",
        "payment instructions",
        "has been processed",
        "has been credited to your fab account",
        "cash deposit",
        "cheque credited",
        "cheque returned",
        "credit",
        "debit",
        "remittance",
        "available balance"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "funds transfer request of\\s+([A-Z]{3})\\s+([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        },
        {
          "re": "for\\s+([A-Z]{3})\\s+([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        },
        {
          "re": "([A-Z]{3})\\s+\\*([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        },
        {
          "re": "([A-Z]{3})\\s+([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        },
        {
          "re": "Amount\\s*([A-Z]{3})\\s+\\*?([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        },
        {
          "re": "payment.*?([A-Z]{3})\\s+\\*?([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        }
      ],
      "merchant": [
        {
          "re": "(?:Credit|Debit)\\s+Card\\s+Purchase\\s+Card\\s+No\\s+[X\\d]+\\s+[A-Z]{3}\\s+[\\d,.]+\\s+([^0-9]+?)(?:\\s+\\d{2}/\\d{2}/\\d{2})"
        },
        {
          "re": "[A-Z]{3}\\s+[0-9,]+(?:\\.\\d{2})?[ \\t]*\\n(?<value>[^/\\n]+?)[ \\t]*(?:\\n|$)"
        },
        {
          "re": "([A-Z]+\\.(?:COM|NET|ORG|IN)[^\\n]*)"
        }
      ],
      "balance": [
        {
          "re": "available\\s+balance\\s+(?:is\\s+)?([A-Z]{3})\\s*\\*{0,}([0-9,]+(?:\\.\\d{2})?)",
          "group": 2
        }
      ],
      "reference": [
        {
          "re": "(\\d{2}/\\d{2}/\\d{2}\\s+\\d{2}:\\d{2})"
        },
        {
          "re": "Value\\s+Date\\s+(\\d{2}/\\d{2}/\\d{4})"
        }
      ],
      "accountLast4": [
        {
          "re": "from\\s+account\\s+([X\\d]{4,})",
          "takeLast4": true
        },
        {
          "re": "from\\s+(?:your\\s+)?account/card\\s+([X\\d]{4,})",
          "takeLast4": true
        },
        {
          "re": "Card\\s+No\\s+([X\\d]{4})",
          "takeLast4": true
        },
        {
          "re": "Account\\s+([X\\d]{4})",
          "takeLast4": true
        },
        {
          "re": "Account\\s+[X*]+(\\d{4})",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "credit": ["credit card purchase"],
      "expense": [
        "debit card purchase",
        "cheque returned",
        "atm cash withdrawal",
        "outward remittance",
        "payment instructions",
        "has been processed",
        "debit",
        "purchase",
        "payment"
      ],
      "income": [
        "cheque credited",
        "inward remittance",
        "cash deposit",
        "has been credited to your fab account",
        "credit"
      ],
      "transfer": ["funds transfer request"]
    },
    "cardRules": {
      "includeKeywords": ["credit card purchase", "debit card purchase"],
      "excludeKeywords": []
    },
    "cleaning": {
      "stripPatterns": ["\\*"],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["funds transfer request"]
        },
        "field": "transactionType",
        "value": "TRANSFER"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["funds transfer request"]
        },
        "field": "merchant",
        "value": "Transfer"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["payment instructions"]
        },
        "field": "merchant",
        "value": "Transfer"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["has been credited to your fab account"],
          "notContainsAny": ["unsuccessful transaction"]
        },
        "field": "merchant",
        "value": "Account Credited"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["cash withdrawal"]
        },
        "field": "merchant",
        "value": "Cash Withdrawal"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["atm cash withdrawal"]
        },
        "field": "merchant",
        "value": "ATM Withdrawal"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["inward remittance"]
        },
        "field": "merchant",
        "value": "Inward Remittance"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["outward remittance"]
        },
        "field": "merchant",
        "value": "Outward Remittance"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["cash deposit"]
        },
        "field": "merchant",
        "value": "Cash Deposit"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["cheque credited"]
        },
        "field": "merchant",
        "value": "Cheque Credited"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["cheque returned"]
        },
        "field": "merchant",
        "value": "Cheque Returned"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["unsuccessful transaction"]
        },
        "field": "merchant",
        "value": "Refund"
      }
    ]
  },
  "fixtures": [
    {
      "name": "credit card purchase multi-line",
      "sender": "FAB",
      "receivedAt": "2025-09-23T16:17:00.000Z",
      "body": "Credit Card Purchase\nDebit\nAccount XXXX0002\nCard XXXX1234\nAED 8.00\nTR              DUBAI           ARE\n23/09/25 16:17\nAvailable Balance AED 4530.16",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "8.00",
          "transactionType": "CREDIT",
          "merchant": "TR DUBAI ARE",
          "accountLast4": "0002",
          "balance": "4530.16",
          "reference": "23/09/25 16:17",
          "isFromCard": true,
          "currency": "AED"
        }
      }
    },
    {
      "name": "inward remittance",
      "sender": "FAB",
      "receivedAt": "2025-09-18T10:00:00.000Z",
      "body": "Inward Remittance\nCredit\nAccount XXXX5678\nAED 444.00\nValue Date 18/09/2025\nAvailable Balance AED 5444.00",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "444.00",
          "transactionType": "INCOME",
          "merchant": "Inward Remittance",
          "accountLast4": "5678",
          "balance": "5444.00",
          "reference": "18/09/2025"
        }
      }
    },
    {
      "name": "payment instructions processed",
      "sender": "FAB",
      "receivedAt": "2025-09-10T15:28:00.000Z",
      "body": "Dear Customer, Your payment instructions of AED 250.00 to 5xxx**1xxx has been processed on 10/09/2025 15:28",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "250.00",
          "transactionType": "EXPENSE",
          "merchant": "Transfer"
        }
      }
    },
    {
      "name": "debit card purchase THB",
      "sender": "FAB",
      "receivedAt": "2025-07-26T17:55:00.000Z",
      "body": "Debit Card Purchase\nDebit\nAccount XXXX9876\nCard XXXX2865\nTHB 1500.50\nWWW.GRAB.COM          BANGKOK         TH\n26/07/25 17:55\nAvailable Balance AED 8500.25",
      "expected": {
        "confidence": "HIGH",
