      "receivedAt": "2025-06-20T12:00:00.000Z",
      "body": "Cash Deposit\nCredit\nAccount XXXX4321\nAED 10000.00\nDate 20/06/25",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "10000.00",
          "transactionType": "INCOME",
          "merchant": "Cash Deposit",
          "accountLast4": "4321"
        }
      }
    },
    {
      "name": "cheque credited",
      "sender": "FAB",
      "receivedAt": "2024-10-01T08:00:00.000Z",
      "body": "Cheque Credited\nCheque No 000020 for AED 9999.00 deposited in your account XXXX0002 has been credited on 01/10/2024 \nYour available balance is AED 7777.62.",
