          "balance": "15000.00",
          "reference": "18/06/25 13:06",
          "isFromCard": false
        }
      }
    },
    {
      "name": "outward remittance",
      "sender": "FAB",
      "receivedAt": "2024-07-10T09:00:00.000Z",
      "body": "Outward Remittance\nDebit\nAccount XXXX0002\nAED 150.00\nValue Date 10/07/24\nAvailable Balance AED 6337.92",
      "expected": {
