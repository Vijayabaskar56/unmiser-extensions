      "sender": "ICICIB",
      "receivedAt": "2025-11-11T13:27:00.000Z",
      "body": "ICICI Bank Acct XX051 debited for Rs 210.00 on 11-Nov-25; HOTEL SARADHAS credited. UPI:531517664120. Call 18002662 for dispute. SMS BLOCK 051 to 9215676766. 06:57 PM",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "210.00",
          "merchant": "HOTEL SARADHAS",
          "accountLast4": "051",
          "reference": "531517664120",
          "transactionType": "EXPENSE"
        }
      }
    }
  ]
}
