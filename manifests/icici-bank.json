    },
    {
      "name": "regular debit with reference and no merchant",
      "sender": "AX-ICICIT-S",
      "receivedAt": "2025-10-03T12:00:00.000Z",
      "body": "Your account has been successfully debited with Rs 250.00. Reference: TXN123456789",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_MERCHANT"],
        "fields": {
          "amount": "250.00",
