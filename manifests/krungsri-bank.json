{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Ported from the original Cashiro KrungsriBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/KrungsriBankParser.kt), which is a thin subclass of BaseThailandBankParser.kt: canHandle matches the exact sender \"BAY\" or any sender containing \"KRUNGSRI\" / \"AYUDHYA\"; everything else (THB amounts, Thai/English type keywords, \"คงเหลือ/Bal\" balances, \"บช/A/C xNNNN\" accounts, \"at/ร้าน MERCHANT\" merchants, the \"Available limit/วงเงินคงเหลือ\" credit limit, and the OTP/promo skip list) comes from the Thai base class, with reference/account fallbacks inherited from BankParser.kt's CompiledPatterns."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "th.krungsri.bank",
    "type": "sms-parser",
    "name": "Krungsri (Bank of Ayudhya)",
    "country": "TH",
    "currency": "THB",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["BAY"],
      "dltPatterns": ["^.*KRUNGSRI.*$", "^.*AYUDHYA.*$"]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "รหัส",
        "ยืนยัน",
        "สมัคร",
        "โปรโมชั่น",
        "promotion",
        "cashback offer"
      ],
      "requireAnyKeyword": [
        "เงินเข้า",
        "เงินออก",
        "ถอนเงิน",
        "โอนเงิน",
        "ใช้จ่าย",
        "เงินฝาก",
        "รับเงิน",
        "คงเหลือ",
        "บาท",
        "ยอดใช้จ่าย",
        "withdrawal",
        "deposit",
        "transfer",
        "payment",
        "spent",
        "receive",
        "bal",
        "thb",
        "card transaction",
        "card payment",
        "credit card spending",
        "available limit"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)\\s*(?:THB|บาท)"
        },
        {
          "re": "(?:THB|฿)\\s*(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)"
        },
        {
          "re": "(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)\\s*USD"
        }
      ],
      "merchant": [
        {
          "re": "(?:at|ร้าน)\\s+(?<value>[A-Za-z0-9\\s&._-]+?)(?:\\s+(?:A/C|บช|Bal|คงเหลือ|Available|on|$))"
        },
        {
          "re": "at\\s+(?<value>[A-Za-z0-9\\s&._-]+)$"
        }
      ],
      "balance": [
        {
          "re": "(?:Bal|คงเหลือ)\\s+(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)\\s*(?:THB|บาท)"
        },
        {
          "re": "(?:Bal|คงเหลือ)\\s+(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)"
        }
      ],
      "reference": [
        {
          "re": "(?:Ref|Reference|Txn|Transaction)(?:\\s+No)?[:\\s]+(?<value>[A-Z0-9]+)"
        },
        {
          "re": "UPI[:\\s]+(?<value>[0-9]+)"
        },
        {
          "re": "Reference\\s+Number[:\\s]+(?<value>[A-Z0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "(?:A/c|Account|Acct)(?:\\s+No)?\\.?\\s+(?:[Xx\\*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Card\\s+(?:[Xx\\*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "(?:A/c|Account).*?(?<value>\\d+)(?:\\s|$)",
          "takeLast4": true
        },
        {
          "re": "(?:A/C|บช)\\s*x(?<value>\\d{4})",
          "takeLast4": true
        }
      ],
      "creditLimit": [
        {
          "re": "(?:Available limit|วงเงินคงเหลือ)\\s+(?<value>\\d{1,3}(?:,\\d{3})*(?:\\.\\d{1,2})?)\\s*(?:THB|บาท)"
        }
      ]
    },
    "typeRules": {
      "investment": [
        "iccl",
        "indian clearing corporation",
        "nsccl",
        "nse clearing",
        "clearing corporation",
        "nach",
        "ach",
        "ecs",
        "groww",
        "zerodha",
        "upstox",
        "kite",
        "kuvera",
        "paytm money",
        "etmoney",
        "coin by zerodha",
        "smallcase",
        "angel one",
        "angel broking",
        "5paisa",
        "icici securities",
        "icici direct",
        "hdfc securities",
        "kotak securities",
        "motilal oswal",
        "sharekhan",
        "edelweiss",
        "axis direct",
        "sbi securities",
        "mutual fund",
        "sip",
        "elss",
        "ipo",
        "folio",
        "demat",
        "stockbroker",
        "digital gold",
        "sovereign gold",
        "nse",
        "bse",
        "cdsl",
        "nsdl"
      ],
      "credit": ["credit card spending", "ยอดใช้จ่ายต่างประเทศ", "ยอดใช้จ่าย"],
      "expense": [
        "เงินออก",
        "ถอนเงิน",
        "ถอนเงินสด",
        "โอนเงินออก",
        "โอนเงินผ่าน",
        "ใช้จ่ายบัตร",
        "ใช้จ่าย",
        "withdrawal",
        "payment",
        "you spent",
        "transfer out",
        "card payment",
        "card transaction",
        "atm withdrawal"
      ],
      "income": [
        "เงินเข้า",
        "เงินฝาก",
        "รับเงิน",
        "โอนเงินเข้า",
        "รับเงินพร้อมเพย์",
        "รับเงินโอน",
        "เงินฝากเข้า",
        "deposit",
        "receive",
        "transfer in",
        "transfer received"
      ]
    },
    "cardRules": {
      "includeKeywords": [
        "credit card",
        "บัตรเครดิต",
        "card spending",
        "card payment",
        "card transaction",
        "ใช้จ่ายบัตร",
        "ยอดใช้จ่าย",
        "card ending",
        "debit card"
      ],
      "excludeKeywords": ["a/c", "account", "saving account"]
    },
    "cleaning": {
      "stripPatterns": [],
      "minMerchantLength": 2,
      "commonWords": ["ผ่าน", "โดย", "จาก", "ที่", "ไปยัง", "ถึง"]
    }
  },
  "fixtures": [
    {
      "name": "english atm withdrawal with account and balance",
      "sender": "BAY",
      "receivedAt": "2026-06-01T09:10:00.000Z",
      "body": "Krungsri: ATM withdrawal 1,000.00 THB A/C x3344 Bal 9,540.00 THB",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_MERCHANT"],
        "fields": {
          "amount": "1000.00",
          "transactionType": "EXPENSE",
          "accountLast4": "3344",
          "balance": "9540.00"
        }
      }
    },
    {
      "name": "english card payment with merchant",
      "sender": "BAY",
      "receivedAt": "2026-06-02T16:45:00.000Z",
      "body": "Krungsri: Card payment 890.00 THB at 7-ELEVEN A/C x3344",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "890.00",
          "merchant": "7-ELEVEN",
          "transactionType": "EXPENSE",
          "accountLast4": "3344"
        }
      }
    },
    {
      "name": "thai transfer in with account",
      "sender": "BAY",
      "receivedAt": "2026-06-03T13:40:00.000Z",
      "body": "Krungsri: โอนเงินเข้า 6,000.00 บาท บช x3344",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_MERCHANT"],
        "fields": {
          "amount": "6000.00",
          "transactionType": "INCOME",
          "accountLast4": "3344"
        }
      }
    },
    {
      "name": "credit card spending with available limit",
      "sender": "BAY",
      "receivedAt": "2026-06-04T19:22:00.000Z",
      "body": "Krungsri: Credit card spending 2,350.00 THB at CENTRAL WORLD Available limit 47,650.00 THB",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "2350.00",
          "merchant": "CENTRAL WORLD",
          "transactionType": "CREDIT",
          "creditLimit": "47650.00"
        }
      }
    },
    {
      "name": "thai deposit with balance",
      "sender": "BAY",
      "receivedAt": "2026-06-05T11:30:00.000Z",
      "body": "Krungsri: เงินฝากเข้า 4,500.00 บาท บช x3344 คงเหลือ 14,040.00 บาท",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_MERCHANT"],
        "fields": {
          "amount": "4500.00",
          "transactionType": "INCOME",
          "accountLast4": "3344",
          "balance": "14040.00"
        }
      }
    },
    {
      "name": "thai otp message is filter-rejected",
      "sender": "BAY",
      "receivedAt": "2026-06-06T09:00:00.000Z",
      "body": "Krungsri: รหัส OTP ของคุณคือ 123456 ใช้สำหรับยืนยันการทำรายการ ห้ามบอกผู้อื่น",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
