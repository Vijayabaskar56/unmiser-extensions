{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Ported from the original Cashiro UtkarshBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/UtkarshBankParser.kt). Utkarsh Small Finance Bank (SFBL) SuperCard credit-card transactions from UTKSPR / UTKSFB / UTKARSH senders. The Kotlin extractTransactionType() unconditionally returns CREDIT (SuperCard is a credit-card product), so the pipeline force-fills transactionType with CREDIT. Merchant priority follows the Kotlin parser: \"for UPI - <merchant>\" (skipping reference-only tokens), then \"for <merchant> on/at\" (skipping UPI/INR), then the supercard+upi \"UPI Payment\" special case, then base-class patterns, then the \"Utkarsh SuperCard\" fallback."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.utkarsh.card",
    "type": "sms-parser",
    "name": "Utkarsh Bank",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["UTKSPR", "UTKSFB", "UTKARSH"],
      "dltPatterns": ["^.*UTKSPR.*$", "^.*UTKSFB.*$", "^.*UTKARSH.*$"]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "offer",
        "discount",
        "win ",
        "has requested",
        "payment request",
        "collect request",
        "requesting payment",
        "requests rs",
        "ignore if already paid",
        "have received payment",
        "is due",
        "min amount due",
        "minimum amount due",
        "in arrears",
        "is overdue",
        "ignore if paid"
      ],
      "requireAnyKeyword": [
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "merchant": [
        {
          "re": "for\\s+UPI\\s*[-–]\\s*(?<value>(?=[^\\s.]*[a-wy-zA-Z])[^\\s.]+)"
        },
        {
          "re": "for\\s+(?!UPI\\b|INR\\b)(?<value>[^0-9\\s]\\S*?)(?:\\s+on\\s+|\\s+at\\s+|$)"
        },
        {
          "re": "to\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "from\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "at\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+Ref)"
        }
      ],
      "balance": [
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl Bal|Available Balance)[:\\s]+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Updated Balance|Remaining Balance)[:\\s]+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "reference": [
        {
          "re": "(?:Ref|Reference|Txn|Transaction)(?:\\s+No)?[:\\s]+(?<value>[A-Z0-9]+)"
        },
        {
          "re": "UPI[:\\s]+(?<value>[0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "SuperCard\\s+[xX*]*(?<value>\\d{4})"
        },
        {
          "re": "(?:account|a/c)\\s+[xX*]*(?<value>\\d{4})"
        },
        {
          "re": "(?:A/c|Account|Acct)(?:\\s+No)?\\.?\\s+(?:[Xx*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Card\\s+(?:[Xx*]*\\**)?(?<value>\\d+)",
          "takeLast4": true
        }
      ],
      "creditLimit": [
        {
          "re": "Available\\s+limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avl\\s+Lmt:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avail\\s+Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Available\\s+Credit\\s+Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:^|\\s)Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ]
    },
    "cardRules": {
      "includeKeywords": [
        "card ending",
        "card xx",
        "debit card",
        "credit card",
        "card no.",
        "card number",
        "card *",
        "card x"
      ],
      "excludeKeywords": [
        "a/c",
        "account",
        "ac ",
        "acc ",
        "saving account",
        "current account",
        "savings a/c",
        "current a/c"
      ]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s*\\(.*?\\)\\s*$",
        "\\s+Ref\\s+No.*$",
        "\\s+on\\s+\\d{2}.*$",
        "\\s+UPI.*$",
        "\\s+at\\s+\\d{2}:\\d{2}.*$",
        "\\s*-\\s*$",
        "(?:\\s+PVT\\.?\\s*LTD\\.?|\\s+PRIVATE\\s+LIMITED)$",
        "(?:\\s+LTD\\.?|\\s+LIMITED)$"
      ],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["supercard", "upi"],
          "notContainsAny": ["for "]
        },
        "field": "merchant",
        "value": "UPI Payment"
      },
      {
        "kind": "fallbackField",
        "field": "merchant",
        "value": "Utkarsh SuperCard"
      },
      {
        "kind": "fallbackField",
        "field": "transactionType",
        "value": "CREDIT"
      }
    ]
  },
  "fixtures": [
    {
      "name": "upi spend with merchant after 'for UPI -'",
      "sender": "VM-UTKSPR-S",
      "receivedAt": "2026-05-12T10:15:00.000Z",
      "body": "Rs.450.00 spent on your Utkarsh SuperCard xx5678 for UPI - ZOMATO on 12-05-26. Avl Lmt Rs.45,550.00 - UTKSFB",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "450.00",
          "merchant": "ZOMATO",
          "accountLast4": "5678",
          "creditLimit": "45550.00",
          "transactionType": "CREDIT",
          "isFromCard": true
        }
      }
    },
    {
      "name": "upi payment without explicit merchant becomes UPI Payment",
      "sender": "UTKSPR",
      "receivedAt": "2026-05-15T18:40:00.000Z",
      "body": "Rs.1,200.00 paid via UPI from your Utkarsh SuperCard xx5678 on 15-05-26. Avl Lmt Rs.44,350.00 - UTKSPR",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1200.00",
          "merchant": "UPI Payment",
          "accountLast4": "5678",
          "creditLimit": "44350.00",
          "transactionType": "CREDIT",
          "isFromCard": true
        }
      }
    },
    {
      "name": "debit with 'for MERCHANT on' and reference",
      "sender": "AX-UTKSFB-S",
      "receivedAt": "2026-05-18T09:05:00.000Z",
      "body": "Rs.250.00 debited from your Utkarsh SuperCard xx5678 for AMAZONPAY on 18-05-26. Ref No 987654321 - UTKSPR",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "250.00",
          "merchant": "AMAZONPAY",
          "accountLast4": "5678",
          "reference": "987654321",
          "transactionType": "CREDIT",
          "isFromCard": true
        }
      }
    },
    {
      "name": "payment received on supercard account falls back to Utkarsh SuperCard",
      "sender": "VM-UTKSPR-S",
      "receivedAt": "2026-05-20T11:20:00.000Z",
      "body": "Payment of Rs.5,000.00 received on your Utkarsh SuperCard account xx9012 on 20-05-26. Avl Lmt Rs.49,350.00 - UTKSPR",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "5000.00",
          "merchant": "Utkarsh SuperCard",
          "accountLast4": "9012",
          "creditLimit": "49350.00",
          "transactionType": "CREDIT",
          "isFromCard": false
        }
      }
    },
    {
      "name": "otp message is filter-rejected",
      "sender": "UTKSPR",
      "receivedAt": "2026-05-21T08:00:00.000Z",
      "body": "Your OTP for Utkarsh SuperCard transaction is 123456. Do not share it with anyone.",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    },
    {
      "name": "minimum-due reminder is filter-rejected",
      "sender": "VM-UTKSFB-S",
      "receivedAt": "2026-05-25T08:30:00.000Z",
      "body": "Min amount due Rs.500.00 on your Utkarsh SuperCard xx5678 is due by 25-05-26. Ignore if paid - UTKSPR",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
