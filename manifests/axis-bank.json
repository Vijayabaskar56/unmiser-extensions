{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro AxisBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/AxisBankParser.kt) plus the relevant BankParser.kt base-class fallbacks (CompiledPatterns Amount/Balance/Reference/Account/Merchant). Fixture bodies are taken verbatim from AxisBankParserTest.kt."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "in.axis.bank",
    "type": "sms-parser",
    "name": "Axis Bank",
    "country": "IN",
    "currency": "INR",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["AXISBK", "AXISBANK", "AXIS"],
      "dltPatterns": ["AXIS\\s?BANK", "AXISBK", "AXISB", "^[A-Z]{2}-AXIS-S$", "^[A-Z]{2}-AXIS$"]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "offer",
        "discount",
        "cashback offer",
        "win ",
        "has requested",
        "payment request",
        "collect request",
        "requesting payment",
        "requests rs",
        "ignore if already paid",
        "have received payment",
        "is due",
        "min amount due",
        "minimum amount due",
        "in arrears",
        "is overdue",
        "ignore if paid",
        "towards your axis bank"
      ],
      "requireAnyKeyword": [
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)\\s+debited"
        },
        {
          "re": "INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)\\s+credited"
        },
        {
          "re": "Payment\\s+of\\s+INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "merchant": [
        {
          "re": "debited\\s+from\\s+A/c\\s+no\\.\\s+\\S+\\s+on\\s+(?<value>[^0-9]+?)\\d{2}-\\d{2}-\\d{4}"
        },
        {
          "re": "Spent[\\s\\S]*?IST\\s*\\n\\s*(?<value>[^\\n]+?)(?:\\s*\\n|\\s*Avl Limit:|\\s*Avl Lmt|\\s*Not you?)"
        },
        {
          "re": "Spent[\\s\\S]*?\\d{2}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2}\\s*\\n\\s*(?<value>[^\\n]+?)(?:\\s*\\n|\\s*Avl Limit:|\\s*Avl Lmt|\\s*Not you?)"
        },
        {
          "re": "UPI/[^/]+/[^/]+/(?<value>[^\\n]+?)(?:\\s*Not you|\\s*$)"
        },
        {
          "re": "UPI/P2A/[^/]+/(?<value>[^\\n]+?)(?:\\s*Not you|\\s*$)"
        },
        {
          "re": "Info\\s*[-–]\\s*(?<value>[^.\\n]+?)(?:\\.\\s*Chk|\\s*$)"
        },
        {
          "re": "to\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "from\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "at\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+Ref)"
        },
        {
          "re": "for\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref)"
        }
      ],
      "balance": [
        {
          "re": "(?:Bal|Balance|Avl\\s+Bal|Available\\s+Balance)[:\\s]+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl\\s+Bal|Available\\s+Balance)[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl\\s+Bal|Available\\s+Balance)[:\\s]+₹\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Bal|Balance|Avl\\s+Bal|Available\\s+Balance)[:\\s]+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Updated\\s+Balance|Remaining\\s+Balance)[:\\s]+Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:Updated\\s+Balance|Remaining\\s+Balance)[:\\s]+INR\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ],
      "reference": [
        {
          "re": "UPI/[^/]+/(?<value>[0-9]+)"
        },
        {
          "re": "(?:Ref|Reference|Txn|Transaction)(?:\\s+No)?[:\\s]+(?<value>[A-Z0-9]+)"
        },
        {
          "re": "UPI[:\\s]+(?<value>[0-9]+)"
        },
        {
          "re": "Reference\\s+Number[:\\s]+(?<value>[A-Z0-9]+)"
        }
      ],
      "accountLast4": [
        {
          "re": "A/c\\s+no\\.\\s+[Xx*]*(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Card\\s+no\\.\\s+[X*]*(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "Credit\\s+Card\\s+[X*]*(?<value>\\d+)",
          "takeLast4": true
        },
        {
          "re": "(?:A/c|Account|Acct)(?:\\s+No)?\\.?\\s+[Xx*]*(?<value>\\d+)",
          "takeLast4": true
        }
      ],
      "creditLimit": [
        {
          "re": "Avl\\s+Limit:?\\s*INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avl\\s+Lmt\\s+INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Available\\s+limit:?\\s*INR\\s+(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Available\\s+limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avl\\s+Lmt:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Avail\\s+Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "Available\\s+Credit\\s+Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        },
        {
          "re": "(?:^|\\s)Limit:?\\s*Rs\\.?\\s*(?<value>[0-9,]+(?:\\.\\d{2})?)"
        }
      ]
    },
    "typeRules": {
      "investment": [
        "iccl",
        "indian clearing corporation",
        "nsccl",
        "nse clearing",
        "clearing corporation",
        "nach",
        "ecs",
        "groww",
        "zerodha",
        "upstox",
        "kite",
        "kuvera",
        "paytm money",
        "etmoney",
        "smallcase",
        "angel one",
        "angel broking",
        "5paisa",
        "icici securities",
        "icici direct",
        "hdfc securities",
        "kotak securities",
        "motilal oswal",
        "sharekhan",
        "edelweiss",
        "axis direct",
        "sbi securities",
        "mutual fund",
        "sip",
        "elss",
        "ipo",
        "folio",
        "demat",
        "stockbroker",
        "digital gold",
        "sovereign gold",
        "nse",
        "bse",
        "cdsl",
        "nsdl"
      ],
      "expense": ["debited", "withdrawn", "spent", "charged", "paid", "purchase", "deducted"],
      "income": ["credited", "deposited", "received", "refund", "cashback"]
    },
    "cardRules": {
      "includeKeywords": [
        "card ending",
        "card xx",
        "debit card",
        "credit card",
        "card no.",
        "card number",
        "card *",
        "card x"
      ],
      "excludeKeywords": [
        "a/c",
        "account",
        "saving account",
        "current account",
        "savings a/c",
        "current a/c"
      ]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s+Limi$",
        "\\s+Pay$",
        "\\s+SUPE$",
        "\\s*\\(.*?\\)\\s*$",
        "\\s+Ref\\s+No.*",
        "\\s+on\\s+\\d{2}.*",
        "\\s+UPI.*",
        "\\s+at\\s+\\d{2}:\\d{2}.*",
        "\\s*-\\s*$",
        "\\s+PVT\\.?\\s*LTD\\.?$",
        "\\s+PRIVATE\\s+LIMITED$",
        "\\s+LTD\\.?$",
        "\\s+LIMITED$"
      ],
      "minMerchantLength": 2
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["debited from a/c no.", " on axis bank"]
        },
        "field": "merchant",
        "value": "ATM"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["debited"],
          "containsAny": ["atm", "cash withdrawal"]
        },
        "field": "merchant",
        "value": "ATM"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["avl limit", "avl lmt"]
        },
        "field": "transactionType",
        "value": "CREDIT"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["credit card"],
          "containsAny": ["debited", "spent"]
        },
        "field": "transactionType",
        "value": "CREDIT"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": [" cc "],
          "containsAny": ["debited", "spent"]
        },
        "field": "transactionType",
        "value": "CREDIT"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAll": ["info", "salary"]
        },
        "field": "merchant",
        "value": "Salary"
      }
    ]
  },
  "fixtures": [
    {
      "name": "credit card spent format 1 with IST - Swiggy (truncated Limi)",
      "sender": "AX-AXISBK-S",
      "receivedAt": "2025-10-05T09:43:27.000Z",
      "body": "Spent INR 131\nAxis Bank Card no. XX0818\n05-10-25 09:43:27 IST\nSwiggy Limi\nAvl Limit: INR 217162.72\nNot you? SMS BLOCK 0818 to 919951860002",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "131",
          "merchant": "Swiggy",
          "accountLast4": "0818",
          "transactionType": "CREDIT",
          "creditLimit": "217162.72",
          "isFromCard": true
        }
      }
    },
    {
      "name": "credit card spent format 1 - Amazon Pay (truncated Pay)",
      "sender": "AX-AXISBK-S",
      "receivedAt": "2025-10-12T14:30:15.000Z",
      "body": "Spent INR 1299.00\nAxis Bank Card no. XX5678\n12-10-25 14:30:15 IST\nAmazon Pay\nAvl Limit: INR 50000.00\nNot you? SMS BLOCK 5678 to 919951860002",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1299.00",
          "merchant": "Amazon",
          "accountLast4": "5678",
          "transactionType": "CREDIT",
          "creditLimit": "50000.00",
          "isFromCard": true
        }
      }
    },
    {
      "name": "credit card spent format 2 without IST - Avenue Supermarts",
      "sender": "CP-AXISBK-S",
      "receivedAt": "2025-09-01T12:04:18.000Z",
      "body": "Spent\nCard no. XX7441\nINR 562\n01-09-25 12:04:18\nAVENUE SUPE\nAvl Lmt INR 5120.87\nSMS BLOCK 7441 to 919951860002, if not you - Axis Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "562",
          "merchant": "AVENUE",
          "accountLast4": "7441",
          "transactionType": "CREDIT",
          "creditLimit": "5120.87",
          "isFromCard": true
        }
      }
    },
    {
      "name": "credit card spent - BPCL petrol (untruncated all-caps merchant)",
      "sender": "CP-AXISBK-S",
      "receivedAt": "2025-09-22T09:03:41.000Z",
      "body": "Spent INR 500\nAxis Bank Card no. XX6018\n22-09-25 09:03:41 IST\nBPCL ARUNAA\nAvl Limit: INR 17131.47\nNot you? SMS BLOCK 6018 to 919951860002",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500",
          "merchant": "BPCL ARUNAA",
          "accountLast4": "6018",
          "transactionType": "CREDIT",
          "creditLimit": "17131.47",
          "isFromCard": true
        }
      }
    },
    {
      "name": "ATM withdrawal at Axis Bank location",
      "sender": "JD-AXISBK-S",
      "receivedAt": "2025-11-04T16:06:39.000Z",
      "body": "INR 2000.00 debited from A/c no. XX589034 on AXIS BANK L 04-11-2025 16:06:39 IST. Avl bal: INR 98919.81. Not you? SMS BLOCKCARD XX0192 to +919951860002 - Axis Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "2000.00",
          "merchant": "ATM",
          "accountLast4": "9034",
          "transactionType": "EXPENSE",
          "balance": "98919.81",
          "isFromCard": false
        }
      }
    },
    {
      "name": "debit card purchase - BURGRILL (masked alpha account)",
      "sender": "JD-AXISBK-S",
      "receivedAt": "2025-12-04T13:13:27.000Z",
      "body": "INR 209.00 debited from A/c no. XXxxxxy on BURGRILL 04-12-2025 13:13:27 IST. Avl bal: INR xxxxxxx. Not you? SMS BLOCKCARD XX0023 to +919951860002 - Axis Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "209.00",
          "merchant": "BURGRILL",
          "transactionType": "EXPENSE",
          "isFromCard": false
        }
      }
    },
    {
      "name": "debit card purchase - numeric account with balance",
      "sender": "JD-AXISBK-S",
      "receivedAt": "2025-12-02T20:38:23.000Z",
      "body": "INR 500.00 debited from A/c no. XX312225 on MERCHANT ABC 02-12-2025 20:38:23 IST. Avl bal: INR 10000.00. Not you? SMS BLOCKCARD XX0023 to +919951860002 - Axis Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500.00",
          "merchant": "MERCHANT ABC",
          "accountLast4": "2225",
          "transactionType": "EXPENSE",
          "balance": "10000.00"
        }
      }
    },
    {
      "name": "upi debit with P2A payee and reference (synthesized)",
      "sender": "AX-AXISBK-S",
      "receivedAt": "2025-06-09T17:20:10.000Z",
      "body": "INR 120.00 debited\nA/c no. XX9034\n09-06-25, 17:20:10 IST\nUPI/P2A/512345678901/RAMESH KUMAR\nNot you? SMS BLOCKUPI Cust ID to 919951860002 - Axis Bank",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "120.00",
          "merchant": "RAMESH KUMAR",
          "accountLast4": "9034",
          "transactionType": "EXPENSE",
          "reference": "512345678901",
          "isFromCard": false
        }
      }
    },
    {
      "name": "payment received towards credit card is filter-rejected",
      "sender": "AX-AXISBK-S",
      "receivedAt": "2025-10-06T09:00:00.000Z",
      "body": "Payment of INR 5000.00 has been received towards your Axis Bank Credit Card no. XX0818. It will reflect in your card account within 2 working days - Axis Bank",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
