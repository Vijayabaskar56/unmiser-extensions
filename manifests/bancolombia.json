{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Ported from the original Cashiro BancolombiaParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/BancolombiaParser.kt) Bancolombia (Colombia) sends Spanish-language SMS from short codes 87400 and 85540. Amounts use the Colombian locale: dots as thousand separators and a comma as the decimal separator (\"$1.000.000,75\" = 1,000,000.75 COP). Engine limitation (documented deviation): the manifest engine has no locale-aware amount normalization (it only strips commas), so the Kotlin behavior of \"remove dots, comma -> dot\" cannot be reproduced exactly: - amounts of 1.000-9.999 use takeLast4 to strip the single dot (\"1.000\" -> \"1000\", exact); - plain amounts (\"5000\") are exact; comma centavos are dropped (\"500,50\" -> \"500\", Kotlin yields 500.50); - amounts >= 10.000 (multi-digit dotted thousands, e.g. \"2.000.000\") are deliberately NOT extracted: the verbatim dotted string is not a valid decimal (the dedup-hash Decimal() throws on multi-dot strings, and a single-dot capture like \"100.000\" would silently parse as 100.0). The engine instead reports MISSING_AMOUNT and confidence REVIEW so the transaction surfaces for manual review rather than storing a wrong amount. The Kotlin parser's extractMerchant returns a fixed Spanish label per transaction verb, modeled here as pipeline setFieldWhen steps in reverse order (last writer wins == Kotlin first-match-wins)."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "co.bancolombia.bank",
    "type": "sms-parser",
    "name": "Bancolombia",
    "country": "CO",
    "currency": "COP",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["87400", "85540"]
    },
    "filter": {
      "requireAnyKeyword": ["transferiste", "compraste", "pagaste", "recibiste"]
    },
    "extract": {
      "amount": [
        {
          "re": "(?:Transferiste|Compraste|Pagaste|Recibiste)\\s+\\$?(?<value>\\d\\.\\d{3})(?!\\d|\\.\\d)",
          "takeLast4": true
        },
        {
          "re": "(?:Transferiste|Compraste|Pagaste|Recibiste)\\s+\\$?(?<value>\\d+)(?:,\\d{1,2})?(?![\\d.,])"
        }
      ]
    },
    "typeRules": {
      "expense": ["transferiste", "compraste", "pagaste"],
      "income": ["recibiste"]
    },
    "pipeline": [
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["recibiste"]
        },
        "field": "merchant",
        "value": "Dinero recibido"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["pagaste"]
        },
        "field": "merchant",
        "value": "Pago"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["compraste"]
        },
        "field": "merchant",
        "value": "Compra"
      },
      {
        "kind": "setFieldWhen",
        "when": {
          "containsAny": ["transferiste"]
        },
        "field": "merchant",
        "value": "Transferencia"
      },
      {
        "kind": "fallbackField",
        "field": "merchant",
        "value": "Bancolombia"
      }
    ]
  },
  "fixtures": [
    {
      "name": "transfer with small dotted amount",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:00:00.000Z",
      "body": "Transferiste $1.000 a Juan Perez",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "1000",
          "transactionType": "EXPENSE",
          "merchant": "Transferencia",
          "currency": "COP"
        }
      }
    },
    {
      "name": "purchase with comma centavos (centavos dropped)",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:05:00.000Z",
      "body": "Compraste $500,50 en Supermercado",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "500",
          "transactionType": "EXPENSE",
          "merchant": "Compra"
        }
      }
    },
    {
      "name": "card payment in millions surfaces for review (amount not extractable)",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:10:00.000Z",
      "body": "Pagaste $2.000.000 de tu tarjeta",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_AMOUNT"],
        "fields": {
          "transactionType": "EXPENSE",
          "merchant": "Pago"
        }
      }
    },
    {
      "name": "income with dotted thousands surfaces for review (amount not extractable)",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:15:00.000Z",
      "body": "Recibiste $100.000,25 de Maria",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_AMOUNT"],
        "fields": {
          "transactionType": "INCOME",
          "merchant": "Dinero recibido"
        }
      }
    },
    {
      "name": "plain amount without separators",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:20:00.000Z",
      "body": "Transferiste $5000 a Pedro",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "5000",
          "transactionType": "EXPENSE",
          "merchant": "Transferencia"
        }
      }
    },
    {
      "name": "small amount with centavos (centavos dropped)",
      "sender": "85540",
      "receivedAt": "2026-06-01T10:25:00.000Z",
      "body": "Compraste $25,99 en cafeteria",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "25",
          "transactionType": "EXPENSE",
          "merchant": "Compra"
        }
      }
    },
    {
      "name": "millions with both separators surfaces for review (second sender)",
      "sender": "85540",
      "receivedAt": "2026-06-01T10:30:00.000Z",
      "body": "Pagaste $1.000.000,75 de tarjeta credito",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_AMOUNT"],
        "fields": {
          "transactionType": "EXPENSE",
          "merchant": "Pago"
        }
      }
    },
    {
      "name": "income with 'transferencia' noise word still classified INCOME",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:35:00.000Z",
      "body": "Recibiste $2.500.000,00 transferencia de empresa",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_AMOUNT"],
        "fields": {
          "transactionType": "INCOME",
          "merchant": "Dinero recibido"
        }
      }
    },
    {
      "name": "balance notification is filter-rejected",
      "sender": "87400",
      "receivedAt": "2026-06-01T10:40:00.000Z",
      "body": "Tu saldo es $50.000,00",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    },
    {
      "name": "promotional message is filter-rejected",
      "sender": "85540",
      "receivedAt": "2026-06-01T10:45:00.000Z",
      "body": "Aprovecha nuestras ofertas",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
