{
  "$schema": "../manifest.schema.json",
  "notes": [
    "Patterns ported from the original Cashiro CitiBankParser.kt (parser-core/src/main/kotlin/com/ritesh/parser/core/bank/CitiBankParser.kt) plus the relevant BankParser.kt base-class fallbacks. Citi (USA) sends USD credit-card alerts (\"Citi Alert: A $3.01 transaction was made at ...\")."
  ],
  "manifest": {
    "schemaVersion": "1.0",
    "pluginId": "us.citi.card",
    "type": "sms-parser",
    "name": "Citi Bank",
    "country": "US",
    "currency": "USD",
    "version": "1",
    "trust": "bundled",
    "dispatch": {
      "senders": ["CITI", "CITIBANK", "692484"],
      "dltPatterns": ["^[A-Z]{2}-CITI-[A-Z]$", "^.*CITIBANK.*$"]
    },
    "filter": {
      "excludeKeywords": [
        "otp",
        "one time password",
        "verification code",
        "offer",
        "discount",
        "cashback offer",
        "win ",
        "has requested",
        "payment request",
        "collect request",
        "requesting payment",
        "requests rs",
        "ignore if already paid",
        "have received payment",
        "is due",
        "min amount due",
        "minimum amount due",
        "in arrears",
        "is overdue",
        "ignore if paid"
      ],
      "requireAnyKeyword": [
        "citi alert:",
        "transaction was made",
        "card ending",
        "was not present for",
        "view details at citi.com",
        "debited",
        "credited",
        "withdrawn",
        "deposited",
        "spent",
        "received",
        "transferred",
        "paid"
      ]
    },
    "extract": {
      "amount": [
        {
          "re": "\\$(?<value>[0-9,]+(?:\\.[0-9]{2})?)\\s+transaction"
        },
        {
          "re": "transaction.*?\\$(?<value>[0-9,]+(?:\\.[0-9]{2})?)"
        },
        {
          "re": "A\\s+\\$(?<value>[0-9,]+(?:\\.[0-9]{2})?)\\s+transaction"
        }
      ],
      "merchant": [
        {
          "re": "transaction was made at\\s+(?<value>[^.]+?)(?:\\s+on|$)"
        },
        {
          "re": "transaction at\\s+(?<value>[^.]+?)(?:\\s+View|\\.|$)"
        },
        {
          "re": "\\bto\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "\\bfrom\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref|\\s+UPI)"
        },
        {
          "re": "\\bat\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+Ref)"
        },
        {
          "re": "\\bfor\\s+(?<value>[^.\\n]+?)(?:\\s+on|\\s+at|\\s+Ref)"
        }
      ],
      "reference": [
        {
          "re": "on\\s+(?:card ending|(?<value>\\w+\\s+\\d{1,2},\\s+\\d{4}))"
        }
      ],
      "accountLast4": [
        {
          "re": "card ending in\\s+(?<value>\\d{4})",
          "takeLast4": true
        }
      ]
    },
    "typeRules": {
      "expense": ["transaction was made", "card ending", "was not present", "transaction"]
    },
    "cardRules": {
      "includeKeywords": ["card ending", "credit card", "debit card", "card xx"],
      "excludeKeywords": ["a/c", "saving account", "current account"]
    },
    "cleaning": {
      "stripPatterns": [
        "\\s*\\(.*?\\)\\s*$",
        "\\s+Ref\\s+No.*$",
        "\\s+on\\s+\\d{2}.*$",
        "\\s+UPI.*$",
        "\\s+at\\s+\\d{2}:\\d{2}.*$",
        "\\s*-\\s*$",
        "(?:\\s+PVT\\.?\\s*LTD\\.?|\\s+PRIVATE\\s+LIMITED)$",
        "(?:\\s+LTD\\.?|\\s+LIMITED)$"
      ],
      "minMerchantLength": 2
    }
  },
  "fixtures": [
    {
      "name": "standard transaction on dlt sender",
      "sender": "692484",
      "receivedAt": "2026-06-09T10:00:00.000Z",
      "body": "Citi Alert: A $3.01 transaction was made at BP#1234E  on card ending in 1234. View details at citi.com/citimobileapp",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "3.01",
          "merchant": "BP#1234E",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "isFromCard": true
        }
      }
    },
    {
      "name": "card not present transaction",
      "sender": "CITI",
      "receivedAt": "2026-06-09T10:01:00.000Z",
      "body": "Citi Alert: Card ending in 1234 was not present for a $506.39 transaction at WWW Google C. View at citi.com/citimobileapp",
      "expected": {
        "confidence": "HIGH",
        "fields": {
          "amount": "506.39",
          "merchant": "WWW Google C",
          "accountLast4": "1234",
          "transactionType": "EXPENSE",
          "isFromCard": true
        }
      }
    },
    {
      "name": "alternative dlt sender with unextractable merchant",
      "sender": "US-CITI-A",
      "receivedAt": "2026-06-09T10:02:00.000Z",
      "body": "Citi Alert: A $150.00 transaction was made at AMAZON.COM on card ending in 5678. View details at citi.com/citimobileapp",
      "expected": {
        "confidence": "REVIEW",
        "reasons": ["MISSING_MERCHANT"],
        "fields": {
          "amount": "150.00",
          "accountLast4": "5678",
          "transactionType": "EXPENSE",
          "isFromCard": true
        }
      }
    },
    {
      "name": "otp message is filtered out",
      "sender": "CITI",
      "receivedAt": "2026-06-09T10:03:00.000Z",
      "body": "Citi Alert: Your OTP for the $120.00 transaction at AMAZON is 482910. Do not share this code with anyone.",
      "expected": {
        "confidence": "REJECTED",
        "reasons": ["FILTER_REJECTED"]
      }
    }
  ]
}
